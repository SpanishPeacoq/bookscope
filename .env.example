# Copy this file to .env for local development.

# Hugging Face token with access to the selected hosted vision model/provider.
HF_TOKEN=

# Example: openbmb/<exact-minicpm-v-model-or-endpoint>
BOOKSCOPE_HF_MODEL=

# Optional Hugging Face inference provider name when needed.
BOOKSCOPE_HF_PROVIDER=

# Optional alternative when MiniCPM-V is exposed as a Hugging Face Gradio Space.
# Example: openbmb/minicpm-v-4-6-demo
BOOKSCOPE_GRADIO_SPACE=
BOOKSCOPE_GRADIO_API_NAME=/predict
BOOKSCOPE_GRADIO_INPUT_ORDER=minicpm_v46

# Set true only when you want offline sample rows instead of live MiniCPM-V scans.
BOOKSCOPE_DEMO_MODE=false
